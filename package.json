{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "description": "Neur0n AI Powered IDE",
  "author": "Neur0n Team",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "dev:native": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && npm run electron:dev\"",
    "electron:dev": "electron electron/main.cjs",
    "electron:build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 vite build && electron-builder"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.neur0n.app",
    "productName": "Neur0n",
    "compression": "normal",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "electron/icon.svg"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": true
    },
    "mac": {
      "target": "dmg",
      "icon": "electron/icon.svg"
    }
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.13.0",
    "lucide-react": "^0.546.0",
    "monaco-editor": "^0.55.1",
    "motion": "^12.23.24",
    "octokit": "^5.0.5",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.6.0",
    "vite-plugin-monaco-editor": "^1.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "wait-on": "^9.0.10"
  }
}
