{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "description": "Neur0n AI Powered IDE",
  "author": "Neur0n Team",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "dev:native": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && npm run electron:dev\"",
    "electron:dev": "electron electron/main.cjs",
    "electron:build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 vite build && electron-builder"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.neur0n.app",
    "productName": "Neur0n",
    "compression": "normal",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "electron/icon.svg"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": true
    },
    "mac": {
      "target": "dmg",
      "icon": "electron/icon.svg"
    }
  },
  "dependencies": {
    "@google/genai": "^2.0.0",
    "@monaco-editor/react": "^4.6.0",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase": "^10.12.2",
    "lucide-react": "^0.546.0",
    "monaco-editor": "^0.49.0",
    "motion": "^10.18.0",
    "octokit": "^4.0.2",
    "pyodide": "^0.26.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "tailwind-merge": "^2.3.0",
    "vite-plugin-monaco-editor": "^1.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.21.4",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vite-plugin-pyodide": "^0.0.15",
    "wait-on": "^7.2.0"
  }
}
