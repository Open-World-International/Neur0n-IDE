rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Schema Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) 
        && data.uid is string && data.uid.size() <= 128
        && data.email is string && data.email.size() <= 256
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 128))
        && (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 512))
        && (!('provider' in data) || (data.provider is string && data.provider.size() <= 64))
        && data.lastLogin == request.time;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId); // Explicitly restrict list to owner
      
      allow create: if isOwner(userId) 
        && isValidId(userId)
        && isValidUser(incoming())
        && incoming().uid == request.auth.uid;

      allow update: if isOwner(userId)
        && isValidId(userId)
        && isValidUser(incoming())
        && incoming().uid == existing().uid
        && incoming().email == existing().email
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastLogin', 'provider']);

      allow delete: if false; // Users cannot delete their profiles via client SDK
    }
  }
}
